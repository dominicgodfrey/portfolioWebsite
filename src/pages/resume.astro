---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import ExperienceItem from "@/components/ExperienceItem.astro";
import { projects } from "@/data/projects";
import { certifications, awards } from "@/data/certifications";
import { technicalExperience, nonTechnicalExperience } from "@/data/experience";
import { education } from "@/data/education";
import { skills } from "@/data/skills";
import { coursework } from "@/data/coursework";
import { formatMonthYear } from "@/lib/format";
---

<BaseLayout title="Resume · Dominic Sol Godfrey">
  <div class="page">
    <header class="page-head reveal">
      <h1>Resume</h1>
      <p class="lede">
        Experience, projects, and the rest of the picture.
      </p>
    </header>

    <!-- 1. Technical Experience -->
    <section class="section" aria-labelledby="tech-xp">
      <h2 id="tech-xp" class="section-title">Technical Experience</h2>
      <div class="stack">
        {technicalExperience.map((e) => <ExperienceItem entry={e} />)}
      </div>
    </section>

    <!-- 2. Projects -->
    <section class="section" aria-labelledby="projects-h">
      <h2 id="projects-h" class="section-title">Projects</h2>
      <div class="grid grid-projects">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
    </section>

    <!-- 3. Certifications + Awards (combined) -->
    <section class="section" aria-labelledby="certs-h">
      <h2 id="certs-h" class="section-title">Certifications &amp; Awards</h2>
      <ul class="list">
        {
          certifications.map((c) => (
            <li class="row glass">
              <div>
                <p class="row-title">{c.title}</p>
                <p class="row-sub">{c.issuer}</p>
              </div>
              <div class="row-meta">
                {c.date ? (
                  <time datetime={c.date}>{formatMonthYear(c.date)}</time>
                ) : (
                  <span class="row-status">In progress</span>
                )}
                {c.credentialUrl && (
                  <a href={c.credentialUrl} target="_blank" rel="noopener noreferrer">
                    Verify ↗
                  </a>
                )}
              </div>
            </li>
          ))
        }
        {
          awards.map((a) => (
            <li class="row glass">
              <div>
                <p class="row-title">
                  {a.title} <span class="badge">Award</span>
                </p>
                <p class="row-sub">{a.context}</p>
              </div>
              <div class="row-meta">
                <time datetime={a.date}>{formatMonthYear(a.date)}</time>
              </div>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- 4. Skills -->
    <section class="section" aria-labelledby="skills-h">
      <h2 id="skills-h" class="section-title">Skills</h2>
      <div class="panel glass">
        {
          skills.map((g) => (
            <div class="skill-group">
              <p class="skill-cat">{g.category}</p>
              <ul class="chips">
                {g.items.map((s) => (
                  <li class="chip">{s}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- 5. Education + Relevant Coursework -->
    <section class="section" aria-labelledby="edu-h">
      <h2 id="edu-h" class="section-title">Education</h2>
      <div class="stack">
        {
          education.map((e) => (
            <ExperienceItem
              entry={{
                id: e.id,
                role: e.degree,
                org: e.school,
                location: e.location,
                start: e.start,
                end: e.end,
                bullets: e.details ?? [],
              }}
            />
          ))
        }
        <div class="panel glass">
          <p class="skill-cat">Relevant Coursework</p>
          <ul class="chips">
            {coursework.map((c) => <li class="chip">{c}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <!-- 6. Non-Technical Experience -->
    <section class="section" aria-labelledby="nontech-xp">
      <h2 id="nontech-xp" class="section-title">Non-Technical Experience</h2>
      <div class="stack">
        {nonTechnicalExperience.map((e) => <ExperienceItem entry={e} />)}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: calc(var(--nav-h) + var(--s-6));
    padding-bottom: var(--s-8);
  }
  .page-head {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--s-6) var(--s-5) var(--s-2);
  }
  .page-head h1 {
    font-size: var(--fs-display);
    margin: 0.3rem 0 0.6rem;
    /* Pearl halo lifts the heading off the busy grid lines behind it. */
    text-shadow:
      0 0 18px var(--c-base),
      0 0 9px var(--c-base),
      0 0 3px var(--c-base);
  }
  .lede {
    color: var(--c-text-muted);
    max-width: 52ch;
  }

  /* Section titles pop against the background grid: a soft pearl halo for
     legibility plus a small accent bar for emphasis. */
  .section-title {
    position: relative;
    font-size: var(--fs-h2);
    margin-bottom: var(--s-5);
    padding-left: 0.9rem;
    text-shadow:
      0 0 16px var(--c-base),
      0 0 8px var(--c-base),
      0 0 3px var(--c-base);
  }
  .section-title::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.14em;
    bottom: 0.14em;
    width: 4px;
    border-radius: var(--r-pill);
    background: var(--grad-accent);
  }

  /* Stacked full-width cards (experience). */
  .stack {
    display: grid;
    gap: var(--s-4);
  }

  .grid {
    display: grid;
    gap: var(--s-5);
  }
  .grid-projects {
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  /* Combined certifications + awards list (single column). */
  .list {
    display: grid;
    gap: var(--s-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    padding: var(--s-4) var(--s-5);
    border-radius: var(--r-card);
  }
  .row-title {
    font-weight: 500;
  }
  .row-sub {
    font-size: var(--fs-small);
    color: var(--c-text-muted);
  }
  .row-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    font-size: var(--fs-small);
    color: var(--c-text-muted);
    white-space: nowrap;
  }
  .row-meta a {
    color: var(--c-cyan);
  }
  .row-status {
    font-style: italic;
    color: var(--c-violet);
  }
  .badge {
    display: inline-block;
    margin-left: 0.4rem;
    padding: 0.05rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    border-radius: var(--r-pill);
    background: var(--grad-accent);
    color: #fff;
    vertical-align: middle;
  }

  /* Skills + coursework panels. */
  .panel {
    padding: var(--s-5);
    border-radius: var(--r-card);
    display: grid;
    gap: var(--s-5);
  }
  .skill-group {
    display: grid;
    gap: var(--s-3);
  }
  .skill-cat {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
