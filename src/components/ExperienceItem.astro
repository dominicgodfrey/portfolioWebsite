---
import type { ExperienceEntry } from "@/data/experience";
import { formatMonthYear } from "@/lib/format";

interface Props {
  entry: ExperienceEntry;
}
const { entry } = Astro.props;
// "Present" and free-form labels (e.g. "Expected Graduation Spring 2027") pass
// through untouched; only strict YYYY-MM strings get month-name formatting.
const fmt = (d: string) =>
  /^\d{4}-\d{2}/.test(d) ? formatMonthYear(d) : d;
// With no start date, render just the end label (used by Education).
const dateLabel = entry.start
  ? `${fmt(entry.start)} – ${fmt(entry.end)}`
  : fmt(entry.end);
// Show the bare domain (+ path) as the link label; href keeps the full URL.
const linkLabel = entry.link
  ? entry.link.replace(/^https?:\/\//, "").replace(/^www\./, "").replace(/\/$/, "")
  : "";
---

<article class="xp glass">
  <header class="xp-head">
    <div class="xp-headline">
      {
        entry.logo && (
          <img
            class="xp-logo"
            src={entry.logo}
            alt={`${entry.org} logo`}
            loading="lazy"
          />
        )
      }
      <div class="xp-titles">
        <h3 class="xp-role">{entry.role}</h3>
        <p class="xp-org">
          {entry.org}{entry.location && <span> · {entry.location}</span>}
        </p>
      </div>
    </div>
    <div class="xp-meta">
      <time class="xp-dates">{dateLabel}</time>
      {
        entry.link && (
          <a
            class="xp-link"
            href={entry.link}
            target="_blank"
            rel="noopener noreferrer"
          >
            {linkLabel} ↗
          </a>
        )
      }
    </div>
  </header>
  <ul class="xp-bullets">
    {entry.bullets.map((b) => <li>{b}</li>)}
  </ul>
</article>

<style>
  .xp {
    padding: var(--s-5);
    border-radius: var(--r-card);
  }
  .xp-head {
    display: flex;
    justify-content: space-between;
    /* Top-align the two columns so the date/link line up with the job title,
       independent of the logo height (baseline alignment is thrown off by the
       logo tile participating in the header's baseline). */
    align-items: flex-start;
    gap: var(--s-4);
    flex-wrap: wrap;
  }
  /* Logo + (title/company/location) sit in the top-left corner; the logo height
     matches the text block and uses the same gap the header already uses. */
  .xp-headline {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    min-width: 0;
  }
  .xp-logo {
    flex-shrink: 0;
    width: auto;
    height: 2.9rem;
    max-width: 92px;
    /* White tile frames every logo uniformly — clean behind transparent marks
       and a tidy badge around ones with their own colored backdrop. */
    object-fit: contain;
    background: #fff;
    padding: 5px;
    border-radius: 8px;
    border: 1px solid var(--glass-border);
  }
  .xp-role {
    font-size: var(--fs-h3);
  }
  .xp-org {
    color: var(--c-text-muted);
    font-size: var(--fs-small);
    margin-top: 0.15rem;
  }
  .xp-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    text-align: right;
  }
  .xp-dates {
    color: var(--c-text-muted);
    font-size: var(--fs-small);
    white-space: nowrap;
  }
  .xp-link {
    color: var(--c-cyan);
    font-size: var(--fs-small);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .xp-link:hover {
    color: var(--c-violet);
  }
  .xp-bullets {
    margin: var(--s-3) 0 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.35rem;
    color: var(--c-text-muted);
    font-size: var(--fs-small);
    line-height: 1.55;
  }
  .xp-bullets li::marker {
    color: var(--c-cyan);
  }
</style>
