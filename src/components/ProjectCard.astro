---
import { siGithub } from "simple-icons";
import type { Project } from "@/data/projects";
import { formatMonthRange, formatMonthYear } from "@/lib/format";

interface Props {
  project: Project;
}
const { project } = Astro.props;
const start = project.startDate ?? project.date;
const worked = project.inProgress
  ? `${formatMonthYear(start)} – Present`
  : formatMonthRange(start, project.date);
---

<article class="card glass glass-refract">
  {
    project.image && (
      <div class="card-media">
        <img src={project.image} alt={`${project.title} cover`} loading="lazy" />
      </div>
    )
  }

  <div class="card-body">
    <header class="card-head">
      <div class="card-title-row">
        <h3>{project.title}</h3>
        <time datetime={project.date}>{worked}</time>
      </div>
      {
        (project.badge || project.inProgress) && (
          <div class="card-tags">
            {project.badge && <span class="tag tag-accent">{project.badge}</span>}
            {project.inProgress && (
              <span class="tag tag-progress">In progress</span>
            )}
          </div>
        )
      }
    </header>

    <p class="card-desc">{project.description}</p>

    <ul class="card-stack" aria-label="Tech stack">
      {project.techStack.map((t) => <li class="chip">{t}</li>)}
    </ul>

    <div class="card-links">
      {
        project.liveUrl && (
          <a
            class="btn"
            href={project.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Live demo
          </a>
        )
      }
      {
        project.videoUrl && !project.liveUrl && (
          <a
            class="btn"
            href={project.videoUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Watch demo
          </a>
        )
      }
      {
        project.devpostUrl && (
          <a
            class="btn"
            href={project.devpostUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Devpost
          </a>
        )
      }
      {
        project.githubUrl && (
          <a
            class="btn"
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path d={siGithub.path} fill="currentColor" />
            </svg>
            Code
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--r-card);
    transition:
      transform var(--dur-med) var(--ease-out),
      border-color var(--dur-med) var(--ease-out);
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(168, 85, 247, 0.4);
  }

  .card-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--glass-border);
  }
  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-5);
    flex: 1;
  }

  .card-head {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .card-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
  }
  .card-head h3 {
    font-size: var(--fs-h3);
  }
  .card-head time {
    font-size: var(--fs-small);
    color: var(--c-text-muted);
    white-space: nowrap;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .tag {
    font-size: var(--fs-small);
    line-height: 1;
    padding: 0.3em 0.6em;
    border-radius: var(--r-pill, 999px);
    border: 1px solid transparent;
    font-weight: 600;
  }
  .tag-accent {
    color: var(--c-violet);
    border-color: rgba(147, 51, 234, 0.45);
    background: rgba(147, 51, 234, 0.12);
  }
  .tag-progress {
    color: var(--c-text-muted);
    border-color: var(--glass-border);
    background: rgba(255, 255, 255, 0.05);
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
  }
  .tag-progress::before {
    content: "";
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
    animation: pulse 2s var(--ease-out, ease-out) infinite;
  }
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
    }
    70% {
      box-shadow: 0 0 0 0.4em rgba(34, 197, 94, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .tag-progress::before {
      animation: none;
    }
  }

  .card-desc {
    color: var(--c-text-muted);
    font-size: var(--fs-small);
    line-height: 1.6;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: auto;
    padding-top: var(--s-2);
  }
</style>
